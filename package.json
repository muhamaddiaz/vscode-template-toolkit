{
    "name": "tt",
    "displayName": "Template Toolkit",
    "description": "VS Code support for Perl Template Toolkit syntax",
    "version": "0.1.0",
    "publisher": "muhamaddiaz",
    "repository": {
        "type": "git",
        "url": "https://github.com/muhamaddiaz/vscode-template-toolkit"
    },
    "main": "./extension.js",
    "engines": {
        "vscode": "^1.74.0"
    },
    "activationEvents": [
        "onLanguage:tt"
    ],
    "license": "MIT",
    "categories": [
        "Programming Languages",
        "Snippets"
    ],
    "keywords": [
        "tt",
        "perl",
        "template",
        "template toolkit"
    ],
    "icon": "logo.png",
    "galleryBanner": {
        "color": "#00aaf0",
        "theme": "light"
    },
    "contributes": {
        "languages": [
            {
                "id": "tt",
                "aliases": [
                    "Template Toolkit",
                    "tt",
                    "tt3"
                ],
                "extensions": [
                    ".tt",
                    ".tt3",
                    ".html.tt"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "tt",
                "scopeName": "source.tt3",
                "path": "./syntaxes/TT3.tmLanguage"
            },
            {
                "language": "tt",
                "scopeName": "source.tt2",
                "path": "./syntaxes/TT2.tmLanguage"
            },
            {
                "language": "tt",
                "scopeName": "text.html.tt3",
                "path": "./syntaxes/HTML+TT3.tmLanguage",
                "embeddedLanguages": {
                    "text.html.basic": "html",
                    "source.css": "css",
                    "source.js": "javascript"
                }
            },
            {
                "language": "tt",
                "scopeName": "text.html.tt2",
                "path": "./syntaxes/HTML+TT2.tmLanguage",
                "embeddedLanguages": {
                    "text.html.basic": "html",
                    "source.css": "css",
                    "source.js": "javascript"
                }
            }
        ],
        "snippets": [
            {
                "language": "tt",
                "path": "./snippets/snippets.json"
            },
            {
                "language": "html",
                "path": "./snippets/snippets.json"
            }
        ],
        "configurationDefaults": {
            "emmet.includeLanguages": {
                "tt": "html"
            },
            "[tt]": {
                "editor.formatOnSave": true,
                "editor.formatOnPaste": true
            }
        }
    },
    "dependencies": {
        "js-beautify": "^1.15.4"
    }
}
